using Gtk 4.0;
using Adw 1;

template $ChatSettingsDialog : Adw.PreferencesWindow {
  title: _("Chat Settings");
  default-width: 400;
  default-height: 300;

  Adw.PreferencesPage {
    Adw.PreferencesGroup {
      title: _("General");

      Adw.EntryRow title_entry {
        title: _("Chat Title");
      }
    }

    Adw.PreferencesGroup {
      title: _("System Prompt");

      Adw.EntryRow system_prompt_entry {
        title: _("System Prompt");
      }
    }
  }
}
